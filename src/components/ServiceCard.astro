---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const { icon, title, description, href } = Astro.props;
---

<a href={href} class="group block p-8 bg-white border border-border rounded-2xl hover:border-teal/30 hover:shadow-lg transition-all duration-300">
  <div class="w-14 h-14 flex items-center justify-center bg-teal-light/30 text-teal rounded-xl text-2xl mb-6 group-hover:bg-teal group-hover:text-white transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-xl font-bold text-navy mb-3">{title}</h3>
  <p class="text-text-muted text-sm leading-relaxed mb-4">{description}</p>
  <span class="inline-flex items-center text-sm font-medium text-teal group-hover:gap-2 transition-all">
    詳しく見る
    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
