---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const { icon, title, description, href } = Astro.props;
---

<a href={href} class="group block p-8 bg-white border border-border rounded-2xl hover:border-navy-200 transition-all duration-200">
  <div class="w-12 h-12 flex items-center justify-center bg-accent-light text-accent rounded-xl mb-6 group-hover:bg-accent group-hover:text-white transition-colors duration-200">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-bold text-gray-900 mb-2">{title}</h3>
  <p class="text-text-secondary text-sm leading-relaxed mb-4">{description}</p>
  <span class="inline-flex items-center text-sm font-medium text-accent group-hover:gap-2 transition-all duration-200">
    詳しく見る
    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
