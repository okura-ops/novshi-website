---
interface Props {
  title: string;
  subtitle?: string;
  showCTA?: boolean;
  compact?: boolean;
}

const { title, subtitle, showCTA = false, compact = false } = Astro.props;
---

<section class:list={[
  'relative',
  compact ? 'pt-16 pb-20 lg:pt-20 lg:pb-28' : 'pt-20 pb-24 lg:pt-32 lg:pb-40',
]}>
  <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
    {!compact && (
      <div class="mb-12 fade-in-up">
        <picture>
          <source srcset="/logo-black-lg.webp" type="image/webp" />
          <img src="/logo-black-lg.png" alt="" class="h-10 lg:h-12 w-auto opacity-20" aria-hidden="true" />
        </picture>
      </div>
    )}

    <h1 class:list={[
      'font-bold text-gray-900 fade-in-up',
      compact
        ? 'text-2xl lg:text-[2.25rem]'
        : 'text-[2.5rem] leading-[1.15] sm:text-5xl lg:text-[3.5rem] lg:leading-[1.1]',
    ]}>
      {title}
    </h1>

    {subtitle && (
      <p class:list={[
        'mt-5 lg:mt-6 text-text-secondary max-w-xl fade-in-up',
        compact ? 'text-base' : 'text-lg lg:text-xl leading-relaxed',
      ]}>
        {subtitle}
      </p>
    )}

    {showCTA && (
      <div class="mt-10 flex flex-wrap gap-4 fade-in-up">
        <a
          href="/services"
          class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold text-white bg-accent rounded-md hover:bg-accent-hover transition-colors duration-200"
        >
          サービスを見る
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold text-gray-900 border border-gray-300 rounded-md hover:border-gray-900 transition-colors duration-200"
        >
          お問い合わせ
        </a>
      </div>
    )}
  </div>
</section>
