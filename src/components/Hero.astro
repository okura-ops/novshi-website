---
interface Props {
  title: string;
  subtitle?: string;
  showCTA?: boolean;
  compact?: boolean;
}

const { title, subtitle, showCTA = false, compact = false } = Astro.props;
---

<section class:list={[
  'relative overflow-hidden',
  compact ? 'py-16 lg:py-24' : 'py-24 lg:py-40',
]}>
  <!-- Geometric accent -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-teal-light/20 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal/5 rounded-full translate-y-1/2 -translate-x-1/3 blur-3xl"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class:list={[
      'font-bold tracking-tight text-navy',
      compact ? 'text-3xl lg:text-4xl' : 'text-4xl sm:text-5xl lg:text-6xl',
    ]}>
      {title}
    </h1>

    {subtitle && (
      <p class:list={[
        'mt-6 text-text-muted max-w-2xl mx-auto',
        compact ? 'text-base lg:text-lg' : 'text-lg lg:text-xl',
      ]}>
        {subtitle}
      </p>
    )}

    {showCTA && (
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/services"
          class="inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-white bg-teal rounded-lg hover:bg-teal-dark transition-colors"
        >
          サービスを見る
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 text-base font-medium text-teal border-2 border-teal rounded-lg hover:bg-teal hover:text-white transition-all"
        >
          お問い合わせ
        </a>
      </div>
    )}
  </div>
</section>
