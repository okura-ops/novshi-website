---
interface Props {
  title: string;
  subtitle?: string;
  showCTA?: boolean;
  compact?: boolean;
  dark?: boolean;
}

const { title, subtitle, showCTA = false, compact = false, dark = false } = Astro.props;
---

<section class:list={[
  'relative overflow-hidden',
  compact ? 'py-16 lg:py-24' : 'py-28 lg:py-44',
  dark ? 'bg-navy-950' : 'bg-white',
]}>
  {!dark && (
    <>
      <div class="absolute top-0 right-0 w-80 h-80 bg-navy-50 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-gray-100/50 rounded-full translate-y-1/2 -translate-x-1/3 blur-3xl"></div>
    </>
  )}

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class:list={[
      'font-bold tracking-tight',
      compact ? 'text-3xl lg:text-4xl' : 'text-4xl sm:text-5xl lg:text-[3.5rem]',
      dark ? 'text-white' : 'text-gray-900',
    ]}>
      {title}
    </h1>

    {subtitle && (
      <p class:list={[
        'mt-6 max-w-2xl mx-auto',
        compact ? 'text-base lg:text-lg' : 'text-lg lg:text-xl',
        dark ? 'text-gray-400' : 'text-text-secondary',
      ]}>
        {subtitle}
      </p>
    )}

    {showCTA && (
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/services"
          class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-white bg-accent rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 transition-all duration-200"
        >
          サービスを見る
        </a>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-3.5 text-base font-semibold text-accent border-2 border-accent rounded-lg hover:bg-accent-light transition-all duration-200"
        >
          お問い合わせ
        </a>
      </div>
    )}
  </div>
</section>
