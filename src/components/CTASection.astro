---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'まずはお気軽にご相談ください',
  subtitle = 'サービスに関するご質問・ご相談は無料で承っております。',
} = Astro.props;
---

<section class="py-20 lg:py-28 bg-bg-secondary">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-in-up">
    <h2 class="text-2xl lg:text-3xl font-bold text-gray-900">{title}</h2>
    <p class="mt-4 text-text-secondary">{subtitle}</p>
    <a
      href="/contact"
      class="inline-flex items-center justify-center mt-8 px-10 py-4 text-base font-semibold text-white bg-accent rounded-lg hover:bg-accent-hover hover:-translate-y-0.5 transition-all duration-200"
    >
      お問い合わせ
    </a>
  </div>
</section>
