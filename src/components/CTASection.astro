---
interface Props {
  title?: string;
  subtitle?: string;
}
const {
  title = 'まずはお気軽にご相談ください',
  subtitle = 'サービスに関するご質問・ご相談は無料で承っております。',
} = Astro.props;
---

<section class="py-24 lg:py-32 bg-bg-secondary">
  <div class="max-w-2xl mx-auto px-5 sm:px-8 text-center fade-in-up">
    <h2 class="text-2xl lg:text-3xl font-bold text-gray-900">{title}</h2>
    <p class="mt-4 text-text-secondary text-base">{subtitle}</p>
    <a
      href="/contact"
      class="inline-flex items-center justify-center mt-8 px-8 py-4 text-sm font-semibold text-white bg-accent rounded-md hover:bg-accent-hover transition-colors duration-200"
    >
      お問い合わせ
    </a>
  </div>
</section>
