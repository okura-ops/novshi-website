---
interface TimelineItem {
  period: string;
  company: string;
  role: string;
  detail?: string;
}
interface Props { items: TimelineItem[]; }
const { items } = Astro.props;
---

<div class="relative">
  <div class="absolute left-0 top-2 bottom-2 w-px bg-gray-200"></div>

  <div class="space-y-10">
    {items.map((item, index) => (
      <div class="relative pl-8 fade-in-up">
        <div class:list={[
          'absolute -left-[3px] top-2 w-[7px] h-[7px] rounded-full',
          index === items.length - 1 ? 'bg-accent' : 'bg-gray-300',
        ]}></div>

        <p class="text-xs font-medium text-text-muted tracking-wider mb-1">{item.period}</p>
        <h3 class="text-base font-bold text-gray-900">{item.company}</h3>
        <p class="text-sm text-text-secondary mt-0.5">{item.role}</p>
        {item.detail && <p class="text-xs text-text-muted mt-1">{item.detail}</p>}
      </div>
    ))}
  </div>
</div>
