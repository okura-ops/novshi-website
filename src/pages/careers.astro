---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="採用情報 | 株式会社novshi" description="novshiの採用情報。AIと協働する新しい働き方で、九州の地域課題を解決しませんか。">
  <Hero title="novshiで働く" subtitle="AIと協働する新しい働き方で、九州から地域課題を解決する。" compact={true} />

  <section class="py-24 lg:py-32">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <div class="space-y-6 text-text-secondary leading-[1.9]">
          <p>novshiは社員ゼロ・AI駆動型経営を実践する、新しいタイプの会社です。AIをツールとしてではなく、経営の中核に据え、少人数で大きなインパクトを生み出しています。</p>
          <p>九州を拠点に、地方中小企業の採用課題を解決するHR事業と、空き家を再生して社宅に転換する不動産事業を展開。テクノロジーと現場の両方を理解する人材を求めています。</p>
        </div>

        <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-px bg-gray-200 border border-gray-200 rounded-xl overflow-hidden stagger">
          {[
            { label: 'AIとの協働', desc: 'Claude、GPT、各種AIツールを日常的に活用する環境' },
            { label: '裁量の大きさ', desc: '少人数組織だからこそ、一人ひとりの意思決定が事業に直結' },
            { label: '九州 × 全国', desc: '九州を拠点に、全国の企業にサービスを提供' },
          ].map((item) => (
            <div class="bg-white p-8">
              <p class="text-sm font-bold text-gray-900 mb-2">{item.label}</p>
              <p class="text-xs text-text-secondary leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-bg-secondary">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">募集ポジション</h2>
        <p class="text-text-secondary mb-8">具体的な募集ポジションは現在準備中です。カジュアル面談はいつでも受け付けていますので、お気軽にお問い合わせください。</p>
        <a href="/contact" class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold text-white bg-accent rounded-md hover:bg-accent-hover transition-colors duration-200">
          カジュアル面談を申し込む
        </a>
      </div>
    </div>
  </section>

  <CTASection title="novshiに興味がありますか？" subtitle="まずはカジュアルにお話ししましょう。ポジションに関わらず、お気軽にご連絡ください。" />
</Layout>
