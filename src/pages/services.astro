---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="サービス | 株式会社novshi" description="採用戦略・運用支援、外国人採用・定着支援、AI活用支援。九州の地方中小企業の採用課題を一気通貫で解決します。">
  <Hero title="採用の上流から下流まで、一気通貫で支援" subtitle="九州×エッセンシャルワーカーの採用を、戦略設計から実行・改善まで。" compact={true} />

  <!-- 3 Channel -->
  <section class="py-20 lg:py-24 bg-bg-secondary">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4 fade-in-up">3チャネル認知戦略</h2>
      <p class="text-text-secondary mb-12 fade-in-up">求職者の接点を多角的に設計し、採用力を最大化します。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-gray-200 border border-gray-200 rounded-xl overflow-hidden stagger">
        {[
          { label: 'Indeed', desc: 'スポンサー求人のCPC最適化で応募単価を削減' },
          { label: 'Meta広告', desc: 'Instagram/Facebookで潜在層にリーチ' },
          { label: '自社採用HP', desc: 'AIO対応の構造化情報でAIにも求職者にも見つかる' },
        ].map((ch) => (
          <div class="bg-white p-8 lg:p-10">
            <p class="text-base font-bold text-gray-900 mb-2">{ch.label}</p>
            <p class="text-sm text-text-secondary">{ch.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 柱1 -->
  <section id="recruitment" class="py-24 lg:py-32 scroll-mt-20">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-4">Service 01</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">採用戦略・運用支援</h2>
        <p class="text-text-secondary leading-relaxed">
          「媒体に求人を出す」だけでは、人は来ません。
          限られた母集団に対して、誰に・何を・どう届けるかを戦略的に設計し、データドリブンで改善し続ける。
          novshiは、その一連のプロセスを丸ごとお引き受けします。
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-y-8 gap-x-16 stagger">
        {[
          { title: 'EVP（採用強み）の言語化', desc: '貴社が選ばれる理由を構造的に整理し、採用メッセージとして言語化します。' },
          { title: 'AI求人最適化', desc: 'AirWork Hubを活用し、AI時代の検索行動に最適化された求人を作成します。' },
          { title: 'Indeed運用代行', desc: 'スポンサー求人のCPC最適化、A/Bテスト、効果測定を一括代行します。' },
          { title: 'Meta広告運用', desc: 'Instagram/Facebook採用広告で潜在求職者にリーチ。クリエイティブ制作から運用まで。' },
          { title: '採用HP構築・運用', desc: 'AIO対応の採用専用サイトを構築。求職者にもAIにも選ばれる情報設計を実現します。' },
          { title: 'KPIモニタリング・改善', desc: '応募数・表示数・CTR・CPAを可視化し、データに基づく継続的な改善を実施します。' },
        ].map((item) => (
          <div class="border-l-2 border-gray-200 pl-6">
            <h3 class="text-sm font-bold text-gray-900 mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 柱2 -->
  <section id="global" class="py-24 lg:py-32 bg-bg-secondary scroll-mt-20">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-4">Service 02</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">外国人採用・定着支援</h2>
        <p class="text-text-secondary leading-relaxed">
          外国人材の採用は「紹介して終わり」ではありません。
          住まい・在留資格・生活基盤の整備まで一貫してサポートすることで、本当の意味での定着を実現します。
        </p>
      </div>

      <div class="mt-14 grid grid-cols-1 sm:grid-cols-2 gap-8 stagger">
        {[
          { title: '住居付き人材紹介', desc: '空き家再生事業と連携し、住居とセットで人材をご紹介。有料職業紹介免許取得済み。', note: '空き家事業連携' },
          { title: '住宅確保支援', desc: '外国人材が安心して暮らせる住まいを確保。保証人問題・契約サポートも対応。', note: '空き家事業連携' },
          { title: '在留資格・行政手続サポート', desc: 'ビザの取得・更新、各種届出など煩雑な行政手続をサポートします。', note: null },
          { title: '定着支援', desc: '生活オリエンテーション、日本語サポート、文化適応支援で長期定着を促進。', note: null },
        ].map((item) => (
          <div class="bg-white p-8 border border-gray-200 rounded-lg">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-sm font-bold text-gray-900">{item.title}</h3>
              {item.note && <span class="text-[10px] font-medium text-accent bg-accent-light px-2 py-0.5 rounded-full whitespace-nowrap">{item.note}</span>}
            </div>
            <p class="text-sm text-text-secondary">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI -->
  <section id="ai" class="py-24 lg:py-32 scroll-mt-20">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.15em] mb-4">Appendix</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">AI活用支援・研修</h2>
        <p class="text-text-secondary leading-relaxed mb-10">
          novshiは創業初日から社員ゼロ・AI駆動型経営を実践しています。
          その実践で培ったナレッジを体系化し、中小企業のAI導入を支援します。
        </p>

        <ul class="space-y-4">
          {[
            'AI-Driven経営の設計・導入コンサルティング',
            '業務プロセスのAI化支援',
            '社内AI研修（プロンプト設計・ツール選定・セキュリティ）',
            'novshiの運用実績に基づく実践的なアドバイス',
          ].map((item) => (
            <li class="text-sm text-text-secondary pl-4 border-l-2 border-gray-200">{item}</li>
          ))}
        </ul>

        <div class="mt-10 p-6 bg-accent-light border border-navy-100 rounded-lg">
          <p class="text-sm text-accent-dark leading-relaxed">
            <span class="font-bold">novshi自身がAIで経営を回している実績</span>が、最大の提案材料です。
            このコーポレートサイトもAIで構築しています。
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
