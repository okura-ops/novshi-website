---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import CTASection from '../components/CTASection.astro';

const timelineItems = [
  { period: '—', company: '丸紅株式会社', role: '事業投資', detail: '大企業での事業投資経験を通じて、事業構造の設計力を習得' },
  { period: '6年間', company: '株式会社リクルート', role: '中途採用営業 / 営業MGR → Indeed事業 企画MGR', detail: '1,000社以上の採用を支援。採用市場の構造と実務を深く理解' },
  { period: '—', company: 'スタートアップ（執行役員）', role: '人事・経営企画・事業開発', detail: '大規模エンジニア採用、組織設計、経営企画を一手に担当' },
  { period: '2025.10', company: '株式会社novshi 創業', role: '代表取締役', detail: '九州を拠点に、HR事業と空き家再生事業を立ち上げ' },
];
---

<Layout title="会社概要 | 株式会社novshi" description="株式会社novshiの会社概要、代表紹介、MVV。">
  <Hero title="会社概要" subtitle="九州に根ざし、テクノロジーの力で地域課題を解決する。" compact={true} />

  <section class="py-20 lg:py-24">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-3xl fade-in-up">
        <h2 class="text-xl font-bold text-gray-900 mb-8">基本情報</h2>
        <dl class="divide-y divide-gray-200">
          {[
            ['社名', '株式会社novshi（ノブシ）'],
            ['代表者', '大倉 佑介'],
            ['設立', '2025年10月'],
            ['所在地', '福岡県・熊本県'],
            ['事業内容', '採用戦略・運用支援 / 外国人採用・定着支援 / AI活用支援 / 空き家再生×社宅事業'],
          ].map(([label, value]) => (
            <div class="flex flex-col sm:flex-row py-4 gap-1 sm:gap-0">
              <dt class="sm:w-1/4 text-xs font-medium text-text-muted uppercase tracking-wider">{label}</dt>
              <dd class="sm:w-3/4 text-sm text-gray-900">{value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32 bg-bg-secondary">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl fade-in-up">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.2em] mb-5">CEO Profile</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">大倉 佑介</h2>
        <p class="text-sm text-text-muted mb-12">Yusuke Okura — 代表取締役</p>

        <div class="mb-14">
          <Timeline items={timelineItems} />
        </div>

        <div class="space-y-5 text-text-secondary leading-[1.9] text-[15px]">
          <p>丸紅での事業投資、リクルートでの1,000社以上の採用支援、スタートアップでの経営企画。それぞれの現場で学んだことを掛け合わせ、novshiを創業しました。</p>
          <p>九州の地方中小企業は、日本経済を下支えするエッセンシャルワーカーを数多く雇用しています。しかし、その採用・定着を支える仕組みは驚くほど整っていません。</p>
          <p>「媒体に求人を出す」だけでは人は来ない時代に、戦略とテクノロジーを届けたい。さらに、外国人材の「住まい」の問題を空き家再生で解決することで、採用と定着を構造的に接続する。novshiだからできる価値提供を追求していきます。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MVV -->
  <section class="py-24 lg:py-32">
    <div class="max-w-[1120px] mx-auto px-5 sm:px-8">
      <div class="max-w-2xl mb-20 fade-in-up">
        <p class="text-xs font-semibold text-accent uppercase tracking-[0.2em] mb-5">MVV</p>
      </div>

      <div class="space-y-20 stagger">
        <div>
          <p class="text-xs font-semibold text-text-muted uppercase tracking-[0.15em] mb-4">Mission</p>
          <h3 class="text-3xl lg:text-[2.75rem] lg:leading-[1.15] font-bold text-gray-900">豊かさを、描きなおす。</h3>
        </div>
        <div>
          <p class="text-xs font-semibold text-text-muted uppercase tracking-[0.15em] mb-4">Vision</p>
          <h3 class="text-2xl lg:text-[2rem] font-bold text-gray-900">九州に、人が来る理由を100つくる。</h3>
        </div>
        <div>
          <p class="text-xs font-semibold text-text-muted uppercase tracking-[0.15em] mb-8">Values</p>
          <div class="space-y-8">
            {[
              { value: '志ドリブン', desc: '利益ではなく志が意思決定の起点。何のためにやるのかを常に問い続ける。' },
              { value: '見えにくい価値を、見に行く', desc: '表面的なデータだけでなく、現場の声・文脈・背景にある本質的な課題を見る。' },
              { value: '利益は燃料、目的地ではない', desc: '利益は持続的な価値提供のための手段。目的と手段を取り違えない。' },
            ].map((item) => (
              <div class="border-l-2 border-gray-200 pl-6">
                <h4 class="text-base font-bold text-gray-900 mb-1">{item.value}</h4>
                <p class="text-sm text-text-secondary">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
