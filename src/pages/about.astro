---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Timeline from '../components/Timeline.astro';
import CTASection from '../components/CTASection.astro';

const timelineItems = [
  { period: '—', company: '丸紅株式会社', role: '事業投資', detail: '大企業での事業投資経験を通じて、事業構造の設計力を習得' },
  { period: '6年間', company: '株式会社リクルート', role: '中途採用営業 / 営業マネージャー → Indeed事業 企画マネージャー', detail: '1,000社以上の採用を支援。採用市場の構造と実務を深く理解' },
  { period: '—', company: 'スタートアップ（執行役員）', role: '人事・経営企画・事業開発', detail: '大規模エンジニア採用、組織設計、経営企画を一手に担当' },
  { period: '2025年10月', company: '株式会社novshi 創業', role: '代表取締役', detail: '九州を拠点に、HR事業と空き家再生事業を立ち上げ' },
];
---

<Layout title="会社概要 | 株式会社novshi" description="株式会社novshiの会社概要、代表紹介、MVV（ミッション・ビジョン・バリュー）。">
  <Hero
    title="会社概要"
    subtitle="九州に根ざし、テクノロジーの力で地域課題を解決する。"
    compact={true}
  />

  <!-- Company Info -->
  <section class="py-16 lg:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <h2 class="text-2xl font-bold text-navy mb-8">基本情報</h2>
        <div class="border border-border rounded-xl overflow-hidden">
          <table class="w-full">
            {[
              ['社名', '株式会社novshi（ノブシ）'],
              ['代表者', '大倉 佑介'],
              ['設立', '2025年10月'],
              ['所在地', '福岡県・熊本県'],
              ['事業内容', '採用戦略・運用支援 / 外国人採用・定着支援 / AI活用支援・研修 / 空き家再生×社宅事業'],
            ].map(([label, value], i) => (
              <tr class:list={[i > 0 && 'border-t border-border']}>
                <th class="px-6 py-4 text-left text-sm font-medium text-text-muted bg-offwhite w-1/3">{label}</th>
                <td class="px-6 py-4 text-sm text-navy">{value}</td>
              </tr>
            ))}
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- CEO Profile -->
  <section class="py-16 lg:py-20 bg-offwhite">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <p class="text-sm font-medium text-teal tracking-widest uppercase mb-4">CEO Profile</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-navy mb-4">代表紹介</h2>

        <div class="flex items-center gap-4 mb-10">
          <div class="w-20 h-20 bg-teal rounded-full flex items-center justify-center text-white font-bold text-2xl" style="font-family: 'Outfit', sans-serif;">
            YO
          </div>
          <div>
            <p class="text-xl font-bold text-navy">大倉 佑介</p>
            <p class="text-sm text-text-muted">Yusuke Okura</p>
            <p class="text-sm text-text-muted">株式会社novshi 代表取締役</p>
          </div>
        </div>

        <div class="mb-12">
          <h3 class="text-lg font-bold text-navy mb-6">経歴</h3>
          <Timeline items={timelineItems} />
        </div>

        <div class="p-8 bg-white border border-border rounded-xl">
          <h3 class="text-lg font-bold text-navy mb-4">代表メッセージ</h3>
          <div class="space-y-4 text-text-muted leading-relaxed text-sm">
            <p>
              丸紅での事業投資、リクルートでの1,000社以上の採用支援、スタートアップでの経営企画——。
              それぞれの現場で学んだことを掛け合わせ、novshiを創業しました。
            </p>
            <p>
              九州の地方中小企業は、日本経済を下支えするエッセンシャルワーカーを数多く雇用しています。
              しかし、その採用・定着を支える仕組みは驚くほど整っていません。
              「媒体に求人を出す」だけでは人は来ない時代に、戦略・テクノロジー・データを届けたい。
            </p>
            <p>
              さらに、外国人材の「住まい」の問題を空き家再生で解決することで、
              採用と定着を構造的に接続する——。novshiだからできる価値提供を追求していきます。
            </p>
            <p>
              「豊かさを、描きなおす。」という言葉には、
              地域にとっての豊かさ、働く人にとっての豊かさ、企業にとっての豊かさを、
              もう一度ゼロから考え直したいという想いを込めています。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MVV -->
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14 fade-in-up">
        <p class="text-sm font-medium text-teal tracking-widest uppercase mb-4">Mission / Vision / Values</p>
        <h2 class="text-2xl lg:text-3xl font-bold text-navy">MVV</h2>
      </div>

      <div class="space-y-12 fade-in-up">
        <!-- Mission -->
        <div class="text-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-teal mb-3">Mission</p>
          <h3 class="text-3xl lg:text-4xl font-bold text-navy">豊かさを、描きなおす。</h3>
        </div>

        <!-- Vision -->
        <div class="text-center">
          <p class="text-xs font-semibold uppercase tracking-widest text-teal mb-3">Vision</p>
          <h3 class="text-2xl lg:text-3xl font-bold text-navy">九州に、人が来る理由を100つくる。</h3>
        </div>

        <!-- Values -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-teal mb-6 text-center">Values</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {[
              { value: '志ドリブン', desc: '利益ではなく志が意思決定の起点。何のためにやるのかを常に問い続ける。' },
              { value: '見えにくい価値を、見に行く', desc: '表面的なデータだけでなく、現場の声・文脈・背景にある本質的な課題を見る。' },
              { value: '利益は燃料、目的地ではない', desc: '利益は持続的な価値提供のための手段。目的と手段を取り違えない。' },
            ].map((item) => (
              <div class="p-6 border border-border rounded-xl text-center">
                <h4 class="font-bold text-navy mb-2">{item.value}</h4>
                <p class="text-xs text-text-muted leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
